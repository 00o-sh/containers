{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  // Opt this fork in to Renovate processing. The Mend-hosted Renovate
  // App skips forks by default (and the upstream preset may also disable
  // them); the local repo config overrides any inherited preset value.
  forkProcessing: "enabled",
  extends: ["github>home-operations/renovate-config"],
  // Clear the inherited helm-docs/helm-schema post-upgrade tasks.
  //
  // The upstream `home-operations/renovate-config` default preset extends
  // `helmPostUpgradeTasks.json5`, which declares `postUpgradeTasks.commands`
  // running `helm-docs` and `helm-schema`. Those are meant for the
  // operator's Helm-chart repos — this is a container-image repo with no
  // charts, so the tasks never do anything useful here.
  //
  // Worse, on the Mend-hosted Renovate Cloud, `allowedCommands` (formerly
  // `allowedPostUpgradeCommands`) is an admin-only trusted-command allowlist
  // that repos can't set, and these two commands are not on Mend's list. So
  // Renovate flags an "Artifact update problem — command has not been added
  // to the allowed list in allowedCommands" on essentially every PR that
  // resolves this preset. Emptying the command list here (repo config
  // replaces preset arrays) removes the tasks and clears the warning.
  postUpgradeTasks: {
    commands: [],
    fileFilters: [],
  },
  customManagers: [
    {
      customType: "regex",
      description: "Process Annotations in Docker Bake",
      managerFilePatterns: ["/(^|/)docker-bake\\.hcl$/"],
      matchStrings: [
        'datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\\n.+ = "(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
    },
    {
      customType: "regex",
      description: "Process Annotations in Dockerfiles",
      managerFilePatterns: ["/(^|/)Dockerfile$/"],
      matchStrings: [
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\\n.+(:\\s|=)(&\\S+\\s)?(?<currentValue>\\S+)",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
    },
    {
      customType: "regex",
      description: "Process trailing renovate annotations in melange/apko YAML and workflow env",
      managerFilePatterns: [
        "/(^|/)(melange|apko)\\.yaml$/",
        "/^\\.github/workflows/.*\\.ya?ml$/",
      ],
      matchStrings: [
        // `key: value # renovate: ...` — melange package.version, workflow
        // env pins, etc. extractVersion is needed for upstreams whose git
        // tags carry a v-prefix (kopia v0.23.0) while melange versions
        // don't — without it Renovate may write the prefixed tag back.
        ".+?:\\s+\"?(?<currentValue>[^\"\\s#]+)\"?\\s+#\\s*renovate:\\s+datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(\\s+versioning=(?<versioning>\\S+))?(\\s+extractVersion=(?<extractVersion>\\S+))?",
        // apko package-list floor pins: `- pkg>=1.2.3 # renovate: ...`.
        // The floor is the Renovate-managed value; the apk resolver still
        // floats upward within it, so the daily cron keeps delivering
        // Wolfi -rN CVE rebuilds without a PR. If Wolfi lags upstream,
        // the bump PR fails apk resolution and sits red until Wolfi
        // catches up — visible lag instead of silent drift.
        "-\\s+[A-Za-z0-9._-]+>=(?<currentValue>[^\\s#]+)\\s+#\\s*renovate:\\s+datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(\\s+versioning=(?<versioning>\\S+))?(\\s+extractVersion=(?<extractVersion>\\S+))?",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
    },
  ],
  customDatasources: {
    qbittorrent: {
      defaultRegistryUrlTemplate: "https://github.com/userdocs/qbittorrent-nox-static/releases/latest/download/dependency-version.json",
      format: "json",
      transformTemplates: ['{"releases":[{"version": qbittorrent}]}'],
    },
    "servarr-develop": {
      defaultRegistryUrlTemplate: "https://{{packageName}}.servarr.com/v1/update/develop/changes?os=linux&runtime=netcore",
      format: "json",
      transformTemplates: ['{"releases":[{"version": $[0].version}]}'],
    },
    "servarr-nightly": {
      defaultRegistryUrlTemplate: "https://{{packageName}}.servarr.com/v1/update/nightly/changes?os=linux&runtime=netcore",
      format: "json",
      transformTemplates: ['{"releases":[{"version": $[0].version}]}'],
    },
    "sonarr-develop": {
      defaultRegistryUrlTemplate: "https://services.sonarr.tv/v1/update/develop/changes?os=linux&runtime=netcore&version=4.0",
      format: "json",
      transformTemplates: ['{"releases":[{"version": $[0].version}]}'],
    },
    plex: {
      defaultRegistryUrlTemplate: "https://plex.tv/api/downloads/5.json",
      format: "json",
      transformTemplates: ['{"releases":[{"version": computer.Linux.version}]}'],
    },
  },
  packageRules: [
    {
      // Repology.org returns intermittent ETIMEDOUT (e.g. Mend run on
      // 2026-05-19 aborted on a `deluge` lookup) and Renovate's
      // external-host-error behavior is hardcoded to abort the entire
      // repository run — taking down PR creation for every other
      // package that cycle. The repology datasource itself has no
      // tunable timeout/retry/mirror knobs (docs.renovatebot.com/
      // modules/datasource/repology/), so the practical fix is to
      // opt out of repology lookups entirely on this fork.
      //
      // Scope: only 3 apps inherited the upstream `datasource=repology`
      // annotation (apps/deluge, apps/transmission, apps/irqbalance,
      // each pinning their Alpine apk version). Those three lose
      // version-bump tracking from this datasource. None are consumed
      // downstream — acceptable per the fork's dormant-apps policy.
      // Migrate them to `datasource=github-releases` (or a custom
      // datasource) if/when they need ongoing tracking.
      description: ["Disable repology datasource — flake source, no tunable resilience"],
      matchDatasources: ["repology"],
      enabled: false,
    },
    {
      description: [
        "Group distroless toolchain updates across managers (mise + workflow env)",
      ],
      matchPackageNames: [
        "chainguard-dev/melange",
        "chainguard-dev/apko",
        "sigstore/cosign",
        "anchore/grype",
      ],
      groupName: "{{depName}}",
      groupSlug: "{{depName}}",
      commitMessageTopic: "{{depName}}",
      semanticCommitType: "chore",
      semanticCommitScope: "distroless",
    },
    {
      description: [
        "Group the Go version: the go.mod directive (gomod) and the mise toolchain pin bump together in one PR",
      ],
      matchManagers: ["gomod", "mise"],
      matchDepNames: ["go"],
      groupName: "golang",
    },
    {
      description: ["Release Rules for Distroless Updates"],
      addLabels: ["distroless/{{parentDir}}"],
      additionalBranchPrefix: "{{parentDir}}-distroless-",
      commitMessageExtra: "( {{currentVersion}} → {{newVersion}} )",
      commitMessageTopic: "{{depName}}",
      matchFileNames: ["distroless/**/apko.yaml", "distroless/**/melange.yaml"],
      semanticCommitScope: "{{parentDir}}-distroless",
      semanticCommitType: "release",
    },
    {
      // Same policy as the docker-bake.hcl rule below: the distroless PR
      // gate (build → structure assertions → melange test → boot smoke →
      // Grype/Trivy HIGH+) is the merge decision. ignoreTests: false means
      // a red gate blocks the automerge — that gate is the whole point.
      description: ["Auto-merge Distroless Updates"],
      matchFileNames: ["distroless/**/apko.yaml", "distroless/**/melange.yaml"],
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
    },
    {
      description: ["Release Rules for App Updates"],
      addLabels: ["app/{{parentDir}}"],
      additionalBranchPrefix: "{{parentDir}}-",
      commitMessageExtra: "( {{currentVersion}} → {{newVersion}} )",
      commitMessageTopic: "{{depName}}",
      matchFileNames: ["**/docker-bake.hcl", "**/Dockerfile"],
      semanticCommitScope: "{{parentDir}}",
      semanticCommitType: "release",
    },
    {
      description: ["Auto-merge App Updates"],
      matchFileNames: ["**/docker-bake.hcl"],
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
    },
    {
      description: ["Allowed Ubuntu Version for Base Images"],
      matchDatasources: ["docker"],
      matchPackageNames: ["/ubuntu/"],
      allowedVersions: "/26\\.04/",
    },
    {
      description: ["Allowed Alpine Version for Base Images"],
      matchDatasources: ["docker"],
      matchFileNames: ["**/Dockerfile"],
      matchPackageNames: ["/alpine/"],
      allowedVersions: "/3\\.24/",
    },
    {
      description: ["Allowed Alpine Version for Postgres Base Images"],
      matchDatasources: ["docker"],
      matchPackageNames: ["/postgres/"],
      allowedVersions: "/alpine3\\.24/",
    },
    {
      description: ["Allowed Python Version for Alpine Base Images"],
      matchDatasources: ["docker"],
      matchFileNames: ["**/Dockerfile"],
      matchPackageNames: ["/python/"],
      allowedVersions: "/3\\.14-alpine3\\.24/",
    },
    {
      description: ["Allowed Python Version for Debian Base Images"],
      matchDatasources: ["docker"],
      matchFileNames: ["**/Dockerfile"],
      matchPackageNames: ["/python/"],
      allowedVersions: "/3\\.14-slim/",
    },
    {
      description: ["Allowed Python Version for ESPHome Base Image"],
      matchDatasources: ["docker"],
      matchFileNames: ["apps/esphome/Dockerfile"],
      matchPackageNames: ["/python/"],
      allowedVersions: "/3\\.13-slim/",
    },
    {
      description: ["Allowed Java Version for NZBHydra2 Base Image"],
      matchDatasources: ["docker"],
      matchFileNames: ["apps/nzbhydra2/Dockerfile"],
      matchPackageNames: ["/amazoncorretto/"],
      allowedVersions: "/17-alpine3\\.24/",
    },
  ],
}
